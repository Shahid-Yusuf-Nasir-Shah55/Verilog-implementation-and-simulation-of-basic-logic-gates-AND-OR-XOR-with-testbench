or gate code for verilog
(

module or_gate(
    input A,
    input B,
    output Y
);

assign Y = A | B;

endmodule


)


testbench

(

`timescale 1ns/1ps

module or_gate_tb;

reg A, B;
wire Y;

or_gate uut (
    .A(A),
    .B(B),
    .Y(Y)
);

initial begin
    $dumpfile("or_gate.vcd");
    $dumpvars(0, or_gate_tb);

    A = 0; B = 0;
    #10 A = 0; B = 1;
    #10 A = 1; B = 0;
    #10 A = 1; B = 1;

    #10 $finish;
end

endmodule


)
