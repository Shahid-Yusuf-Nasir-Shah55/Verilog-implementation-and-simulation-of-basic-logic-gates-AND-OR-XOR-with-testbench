`timescale 1ns/1ps

module uart_rx_tb;

reg clk;
reg rst;
reg rx;

wire [7:0] data_out;
wire data_valid;

uart_rx uut(

    .clk(clk),
    .rst(rst),
    .rx(rx),
    .data_out(data_out),
    .data_valid(data_valid)

);

// Waveform
initial begin

    $dumpfile("uart_rx.vcd");
    $dumpvars(0, uart_rx_tb);

end

// Clock

initial begin

    clk = 0;

    forever #5 clk = ~clk;

end

// Send UART frame

initial begin

    rst = 1;
    rx = 1;

    #20;

    rst = 0;

    // Start Bit

    rx = 0;
    #10;

    // Send A5 = 10100101 (LSB First)

    rx = 1; #10;
    rx = 0; #10;
    rx = 1; #10;
    rx = 0; #10;
    rx = 0; #10;
    rx = 1; #10;
    rx = 0; #10;
    rx = 1; #10;

    // Stop Bit

    rx = 1;
    #20;

    $finish;

end

endmodule


