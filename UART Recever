module uart_rx(

    input clk,
    input rst,
    input rx,

    output reg [7:0] data_out,
    output reg data_valid

);

reg [3:0] bit_count;
reg [7:0] shift_reg;
reg receiving;

always @(posedge clk) begin

    if(rst) begin

        bit_count <= 0;
        receiving <= 0;
        data_valid <= 0;

    end

    else begin

        data_valid <= 0;

        if(!receiving) begin

            if(rx == 0) begin
                receiving <= 1;
                bit_count <= 0;
            end

        end

        else begin

            shift_reg[bit_count] <= rx;

            bit_count <= bit_count + 1;

            if(bit_count == 7) begin

                receiving <= 0;
                data_out <= shift_reg;
                data_valid <= 1;

            end

        end

    end

end

endmodule




