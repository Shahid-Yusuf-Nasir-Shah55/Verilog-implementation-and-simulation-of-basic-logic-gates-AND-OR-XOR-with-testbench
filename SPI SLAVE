module spi_slave(

    input sclk,
    input cs,
    input mosi,

    output reg [7:0] rx_data,
    output reg data_ready

);

reg [7:0] shift_reg;
reg [2:0] bit_count;


always @(posedge sclk) begin

    if(cs) begin

        bit_count <= 0;
        data_ready <= 0;

    end

    else begin

        shift_reg <= {shift_reg[6:0],mosi};

        bit_count <= bit_count + 1;


        if(bit_count == 7) begin

            rx_data <= {shift_reg[6:0],mosi};

            data_ready <= 1;

            bit_count <= 0;

        end

        else begin

            data_ready <= 0;

        end

    end

end


endmodule


