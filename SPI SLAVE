`timescale 1ns/1ps

module spi_slave_tb;


reg sclk;
reg cs;
reg mosi;

wire [7:0] rx_data;
wire data_ready;


spi_slave uut(

.sclk(sclk),
.cs(cs),
.mosi(mosi),

.rx_data(rx_data),
.data_ready(data_ready)

);


// Waveform

initial begin

$dumpfile("spi_slave.vcd");

$dumpvars(0,spi_slave_tb);

end



task send_bit(input b);

begin

mosi=b;

#5;

sclk=1;

#5;

sclk=0;

end

endtask



initial begin


sclk=0;

cs=1;

mosi=0;


#20;


// Enable slave

cs=0;


// Send 10100101

send_bit(1);

send_bit(0);

send_bit(1);

send_bit(0);

send_bit(0);

send_bit(1);

send_bit(0);

send_bit(1);


// Disable slave

cs=1;


#20;


$finish;


end



initial begin

$monitor("Time=%0t CS=%b MOSI=%b RX=%h READY=%b",
$time,cs,mosi,rx_data,data_ready);

end


endmodule

